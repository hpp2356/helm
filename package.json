{
  "name": "helm",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "demo": "pnpm build && node packages/cli/dist/bin/run.js packages/cli/fixtures/tools.json packages/cli/fixtures/script.jsonl packages/cli/fixtures/perms.json",
    "demo:deny": "pnpm build && node packages/cli/dist/bin/run.js packages/cli/fixtures/tools.json packages/cli/fixtures/script.jsonl packages/cli/fixtures/perms-deny-calc.json",
    "demo:token-counter": "tsx demo/pr12-token-counter.ts",
    "demo:first-chat": "tsx demo/pr12-first-chat.ts",
    "demo:tool-use": "tsx demo/pr12-tool-use.ts",
    "demo:agent-loop": "tsx demo/pr12-agent-loop.ts",
    "demo:error-mapping": "tsx demo/pr12-error-mapping.ts",
    "demo:mcp": "tsx demo/pr17-mcp-client.ts",
    "repl": "node packages/cli/dist/bin/run.js repl --provider=deepseek",
    "repl:mcp": "node packages/cli/dist/bin/run.js repl --provider=deepseek --mcp-server=calc=tsx demo/mcp-calc-server.ts"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.9.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
